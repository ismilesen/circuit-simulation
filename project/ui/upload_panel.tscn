[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://ui/upload_panel.gd" id="1"]

[node name="UploadPanel" type="Panel"]
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1")

[node name="Margin" type="MarginContainer" parent="."]
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 16.0
offset_top = 16.0
offset_right = -16.0
offset_bottom = -16.0

[node name="VBox" type="VBoxContainer" parent="Margin"]
anchor_right = 1.0
anchor_bottom = 1.0
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_constants/separation = 8

[node name="Header" type="Label" parent="Margin/VBox"]
text = "Circuit Upload"
theme_override_font_sizes/font_size = 22

[node name="Subheader" type="Label" parent="Margin/VBox"]
text = "Each project pairs one xchem schematic with one spice netlist. Pick a project below and press Run."
autowrap_mode = 3
theme_override_font_sizes/font_size = 11

[node name="ControlsCol" type="VBoxContainer" parent="Margin/VBox"]
size_flags_horizontal = 3
theme_override_constants/separation = 6

[node name="PrimaryRow" type="HBoxContainer" parent="Margin/VBox/ControlsCol"]
size_flags_horizontal = 3
theme_override_constants/separation = 6

[node name="UploadButton" type="Button" parent="Margin/VBox/ControlsCol/PrimaryRow"]
text = "Upload Files…"
size_flags_horizontal = 3

[node name="RunButton" type="Button" parent="Margin/VBox/ControlsCol/PrimaryRow"]
text = "Run Simulation"
size_flags_horizontal = 3

[node name="WorkspaceRow" type="HBoxContainer" parent="Margin/VBox/ControlsCol"]
size_flags_horizontal = 3
theme_override_constants/separation = 6

[node name="SaveWorkspaceButton" type="Button" parent="Margin/VBox/ControlsCol/WorkspaceRow"]
text = "Save Workspace…"
size_flags_horizontal = 3

[node name="LoadWorkspaceButton" type="Button" parent="Margin/VBox/ControlsCol/WorkspaceRow"]
text = "Load Workspace…"
size_flags_horizontal = 3

[node name="UtilityRow" type="HBoxContainer" parent="Margin/VBox/ControlsCol"]
size_flags_horizontal = 3
theme_override_constants/separation = 6

[node name="ClearButton" type="Button" parent="Margin/VBox/ControlsCol/UtilityRow"]
text = "Clear"
size_flags_horizontal = 3

[node name="ThemeToggleButton" type="Button" parent="Margin/VBox/ControlsCol/UtilityRow"]
text = "Dark Theme"
size_flags_horizontal = 3

[node name="DropZone" type="PanelContainer" parent="Margin/VBox"]
custom_minimum_size = Vector2(0, 70)
size_flags_horizontal = 3
size_flags_vertical = 0

[node name="DropZoneMargin" type="MarginContainer" parent="Margin/VBox/DropZone"]
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 10.0
offset_top = 8.0
offset_right = -10.0
offset_bottom = -8.0

[node name="DropZoneVBox" type="VBoxContainer" parent="Margin/VBox/DropZone/DropZoneMargin"]
anchor_right = 1.0
anchor_bottom = 1.0
theme_override_constants/separation = 4

[node name="DropTitle" type="Label" parent="Margin/VBox/DropZone/DropZoneMargin/DropZoneVBox"]
text = "Drop files here"
theme_override_font_sizes/font_size = 13

[node name="DropHint" type="Label" parent="Margin/VBox/DropZone/DropZoneMargin/DropZoneVBox"]
text = "1 xchem (.sch/.sym) + 1 spice (.spice/.cir/.net/.txt). Click + on a card to fill a missing slot."
autowrap_mode = 3
theme_override_font_sizes/font_size = 10

[node name="CardContainer" type="PanelContainer" parent="Margin/VBox"]
size_flags_horizontal = 3
size_flags_vertical = 3

[node name="CardScroll" type="ScrollContainer" parent="Margin/VBox/CardContainer"]
size_flags_horizontal = 3
size_flags_vertical = 3
horizontal_scroll_mode = 0

[node name="ProjectCards" type="VBoxContainer" parent="Margin/VBox/CardContainer/CardScroll"]
size_flags_horizontal = 3
theme_override_constants/separation = 6

[node name="StatusBar" type="PanelContainer" parent="Margin/VBox"]
size_flags_horizontal = 3

[node name="StatusRow" type="HBoxContainer" parent="Margin/VBox/StatusBar"]
theme_override_constants/separation = 6

[node name="StatusPrefix" type="Label" parent="Margin/VBox/StatusBar/StatusRow"]
text = "Status:"
theme_override_font_sizes/font_size = 11

[node name="StatusValue" type="Label" parent="Margin/VBox/StatusBar/StatusRow"]
text = "idle"
theme_override_font_sizes/font_size = 11

[node name="Output" type="RichTextLabel" parent="Margin/VBox"]
custom_minimum_size = Vector2(0, 80)
size_flags_horizontal = 3
size_flags_vertical = 0
fit_content = true
scroll_active = true
selection_enabled = true

[node name="FileDialog" type="FileDialog" parent="."]
access = 2
file_mode = 4
use_native_dialog = true
title = "Select one xchem and/or one spice"
filters = PackedStringArray("*.sch, *.sym, *.spice, *.cir, *.net, *.txt ; Project files (xchem + spice)", "*.sch, *.sym ; Xschem schematics/symbols", "*.spice, *.cir, *.net, *.txt ; Spice netlists")

[node name="WorkspaceDialog" type="FileDialog" parent="."]
access = 2
use_native_dialog = true
title = "Workspace"
